{
  "expo": {
    "name": "DrinkReminder",
    "slug": "drinkreminder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "../release/creo/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "../release/creo/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B57D0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.drinkreminder.app"
    },
    "android": {
      "package": "com.drinkreminder.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "../release/creo/icon.png",
        "backgroundColor": "#0B57D0"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "../release/creo/icon.png"
    },
    "plugins": [
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "../release/creo/icon.png",
          "color": "#0B57D0"
        }
      ]
    ],
    "extra": {
      "apiUrl": "http://10.0.2.2:8000"
    }
  }
}
